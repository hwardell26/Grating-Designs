#Calcuate and display DEs/absorption/EFIs
def calculation_function(duty_cycle, height, layers=None):
    if layers == None:
        layers = [100,100,100,100]
    #inialize base grating
    ucell_1d_m = np.ones((5,1,500))
    cutoff = int(ucell_1d_m.shape[2] * duty_cycle)
    ucell_1d_m[0,0,:cutoff] = n_hfo2 
    #intialize top layers
    ucell_1d_m[1,0,:] = n_hfo2
    ucell_1d_m[2,0,:] = n_sio2
    ucell_1d_m[3,0,:] = n_hfo2
    ucell_1d_m[4,0,:] = n_sio2
    thickness = [height, layers[0], layers[1], layers[2], layers[3]]
    mee = meent.call_mee(backend=0,n_top=n_top,n_bot=n_bot,theta=theta,fto=fto,pol=pol,
    wavelength=wavelength,period=period,ucell=ucell_1d_m,thickness=thickness,type_complex=type_complex)
    #begin solving for DEs/absorption/EFIs
    result1, field_cell = mee.conv_solve_field(res_z=field_res_z,res_y=1,res_x=field_res_x)
    res = result1.res
    de_ri = res.de_ri_s
