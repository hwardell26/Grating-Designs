#Jointly optimize grating/coating layers for duty cycle and height
def minimization_function(x):
    #optimize base grating
    duty_cycle, height, hfo2_1, sio2_1, hfo2_2, sio2_2 = x
    ucell_1d_m = np.ones((5,1,1000))*n_sio2
    cutoff = int(ucell_1d_m.shape[2] * duty_cycle)
    ucell_1d_m[4,0,:cutoff] = np.ones(cutoff)*n_hfo2 #grating
    #optimize top layers/film stack
    ucell_1d_m[3,0,:] = np.ones(ucell_1d_m.shape[2])*n_hfo2
    ucell_1d_m[1,0,:] = np.ones(ucell_1d_m.shape[2])*n_hfo2
    thickness = [sio2_1,hfo2_1, sio2_2,hfo2_2, height]
    #call backend/calculate
    mee = meent.call_mee(backend=0,n_top=n_top,n_bot=n_bot,theta=theta,fto=fto,pol=pol,wavelength=wavelength,
    period=period,ucell=ucell_1d_m,thickness=thickness,type_complex=type_complex)
    res,a = mee.conv_solve_field(res_z=field_res_z,res_y=1,res_x=field_res_x)
    de_ri = res.res.de_ri_s
    print(de_ri[0, fto-1])
    return -de_ri[0, fto-1]

def optimization_parameter_function(x): #optimize optimization parameter(LIDT/EFI) for max energy reaching target
    duty_cycle, height, hfo2_1, sio2_1, hfo2_2, sio2_2 = x
    layers = [hfo2_1, sio2_1, hfo2_2, sio2_2]
    opt_param, _, _, _, _ = calculation_function(duty_cycle, height, layers)
    return opt_param    

