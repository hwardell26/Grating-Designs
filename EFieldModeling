        np.full(res_x, n_hfo2),  # HfO2 layer 1
        np.full(res_x, n_sio2), np.full(res_x, n_hfo2), np.array([n_hfo2 if i < int(res_x * duty_cycle) else n_sio2 for i in range(res_x)])]
