    print(rlist[7], PillarMaxEFI)
    print(rlist[8], TrenchMaxEFI)
    #refractive index map
    res_z, res_x = val.shape
    total_t = sum(thickness)
    z_pixels = [max(1, round(res_z * t / total_t)) for t in thickness]
    z_pixels[0] += res_z - sum(z_pixels)  
